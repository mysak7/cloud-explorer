# Copy to .env and fill in values before running docker compose up
NB_SETUP_KEY=your-netbird-setup-key-here
AWS_PROFILE=default
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Must match your Ubuntu host user — run: id -u && id -g
HOST_UID=1000
HOST_GID=1000

# Optional: GCP (leave blank if not using GCP)
GCP_PROJECT_ID=

# Optional: Azure (leave blank if not using Azure)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
