{
  "mcpServers": {
    "awslabs-core": {
      "command": "uvx",
      "args": ["awslabs.core-mcp-server@latest"]
    },
    "awslabs-aws-api": {
      "command": "uvx",
      "args": ["awslabs.aws-api-mcp-server@latest"]
    },
    "awslabs-knowledge": {
      "command": "uvx",
      "args": ["awslabs.aws-documentation-mcp-server@latest"]
    },
    "aws-agent-memory": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--project", "/workspace/memory", "python", "/workspace/memory/server.py"],
      "env": {
        "PG_CONNECTION_STRING": "postgresql://agent:agent_password@pgvector:5432/agent_memory",
        "AWS_REGION": "eu-central-1"
      }
    },
    "gcp-gcloud": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/gcloud-mcp"]
    },
    "gcp-compute": {
      "type": "http",
      "url": "https://compute.googleapis.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GCP_ACCESS_TOKEN}",
        "x-goog-user-project": "${GCP_PROJECT_ID}"
      }
    },
    "gcp-gke": {
      "type": "http",
      "url": "https://container.googleapis.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GCP_ACCESS_TOKEN}",
        "x-goog-user-project": "${GCP_PROJECT_ID}"
      }
    },
    "gcp-logging": {
      "type": "http",
      "url": "https://logging.googleapis.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GCP_ACCESS_TOKEN}",
        "x-goog-user-project": "${GCP_PROJECT_ID}"
      }
    },
    "azure": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest"],
      "env": {
        "AZURE_SUBSCRIPTION_ID": "${AZURE_SUBSCRIPTION_ID}",
        "AZURE_TENANT_ID": "${AZURE_TENANT_ID}"
      }
    }
  }
}
